# Copy this file to .env on the deployment host and change every placeholder
# before running Docker Compose. Never commit .env.

NODE_ENV=production
APP_COMMIT_SHA=

DOMAIN=kaspa-actions.example.com
NEXT_PUBLIC_APP_URL=https://kaspa-actions.example.com
ACME_EMAIL=admin@example.com

# Required for the private operator dashboard gate at /operator-stats.
# Generate with: caddy hash-password --plaintext 'change-me'
# Keep the hash single-quoted in .env so Compose preserves the `$` characters.
BASIC_AUTH_HASH='replace-with-generated-bcrypt-hash'

POSTGRES_USER=kaspa_actions
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=kaspa_actions
DATABASE_URL=postgresql://kaspa_actions:change-me-postgres-password@postgres:5432/kaspa_actions?schema=public

MOCK_CONFIRM_ENABLED=false
ADMIN_ACCESS_TOKEN=change-me-admin-token

# Creator dashboard. In production, signup is disabled unless this is explicitly
# set to true. Creator tokens are shown once and stored only as hashes.
CREATOR_SIGNUP_ENABLED=false
CREATOR_ACTION_DAILY_LIMIT=50

# Private operator dashboard at /operator-stats. The app reads Caddy access
# logs from this directory inside the app container. Keep the route behind
# Basic Auth or another operator-only gate.
OPERATOR_ACCESS_LOG_DIR=/var/log/caddy

# On-chain payment detection (opt-in). When KASPA_INDEXER_ENABLED=true, the status
# endpoint picks an indexer per PaymentRequest network and flips matching pending
# payment requests to CONFIRMED with the real on-chain tx id. See
# docs/chain-detection.md for the trust model.
KASPA_INDEXER_ENABLED=false

# Mainnet indexer (recommended default: official Kaspa REST API).
KASPA_MAINNET_INDEXER_URL=https://api.kaspa.org
KASPA_MAINNET_INDEXER_PROVIDER_ID=

# Testnet indexer (leave empty to disable testnet auto-confirm).
# Compatible deployments expose the same /addresses/.../full-transactions-page
# shape as api.kaspa.org. Example public mirror: https://api-tn10.kaspa.org
KASPA_TESTNET_INDEXER_URL=
KASPA_TESTNET_INDEXER_PROVIDER_ID=

# Legacy single-network fallback (only used for mainnet when the mainnet-specific
# URL is empty). New deployments should ignore this.
KASPA_INDEXER_URL=
KASPA_INDEXER_PROVIDER_ID=

# Claimable links. Disabled by default for self-hosters until they intentionally
# enable the feature. Claim/refund spends are signed in the browser, then already
# signed transaction JSON is relayed through the internal wRPC relay. The server
# must never receive claim/refund private keys.
TOCCATA_LAB_ENABLED=false
# Private, Caddy-gated experiment. Keep false for public deployments.
TOCCATA_BATCH_LAB_ENABLED=false
# Separately gates the unlinked address-giveaway experiment.
GIVEAWAY_LAB_ENABLED=false
# Managed Cloudflare Turnstile protection for public giveaway entries. The site
# key is public; the secret key must exist only in the deployment environment.
GIVEAWAY_TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAME=kaspalinks.com
TOCCATA_WRPC_RELAY_URL=http://toccata-relay:3010
TOCCATA_RELAY_CONNECT_TIMEOUT_MS=30000
TOCCATA_RELAY_WARM_CONNECT_INTERVAL_MS=60000
TOCCATA_RELAY_SUBMIT_TIMEOUT_MS=20000
