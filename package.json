{
  "name": "kaspa-actions",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "pnpm db:generate && pnpm --filter @kaspa-actions/web build",
    "db:generate": "DATABASE_URL=\"${DATABASE_URL:-postgresql://kaspa_actions:change-me@localhost:5432/kaspa_actions?schema=public}\" prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:validate": "DATABASE_URL=\"${DATABASE_URL:-postgresql://kaspa_actions:change-me@localhost:5432/kaspa_actions?schema=public}\" prisma validate",
    "dev": "pnpm --filter @kaspa-actions/web dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "pnpm db:generate && tsc -p packages/shared/tsconfig.json --noEmit && tsc -p packages/kaspa/tsconfig.json --noEmit && tsc -p packages/kaspa-indexer/tsconfig.json --noEmit && tsc -p packages/embed-button/tsconfig.json --noEmit && tsc -p packages/sdk/tsconfig.json --noEmit && tsc -p packages/wallet-adapter/tsconfig.json --noEmit && tsc -p packages/db/tsconfig.json --noEmit && tsc -p apps/web/tsconfig.json --noEmit"
  },
  "prisma": {
    "seed": "tsx packages/db/src/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.2.10",
    "@types/pg": "8.20.0",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
    "eslint": "10.3.0",
    "prettier": "3.8.3",
    "prisma": "7.8.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "4.5.14",
    "vitest": "0.33.0"
  }
}
